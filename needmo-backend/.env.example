# ── NEEDMO Consult Backend — Environment Variables ───────────────────────────
# Copy to .env and fill in your values. Never commit .env to Git.

# ── Database (Render PostgreSQL) ──────────────────────────────────────────────
# Copy this from Render dashboard → your PostgreSQL service → Connection String
DATABASE_URL=postgresql://user:password@host:5432/needmo_db

# ── SMTP (your cPanel on needmoconsult.com) ───────────────────────────────────
SMTP_HOST=mail.needmoconsult.com
SMTP_PORT=587
SMTP_USER=hello@needmoconsult.com
SMTP_PASSWORD=your_cpanel_email_password

SENDER_NAME=NEEDMO Consult
SENDER_EMAIL=hello@needmoconsult.com
ADMIN_EMAIL=hello@needmoconsult.com

# ── JWT Auth ──────────────────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=replace_with_strong_random_key
JWT_EXPIRE_HOURS=24

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=https://needmoconsult.com,https://needmoconsult.vercel.app

# ── Daily.co Video Calls ───────────────────────────────────────────────────────
# Get your API key from: https://dashboard.daily.co/apikeys
DAILY_API_KEY=your_daily_api_key
DAILY_DOMAIN=https://needmo.daily.co
