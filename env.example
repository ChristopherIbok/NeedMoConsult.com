# ──────────────────────────────────────────────────────────────────────────────
# .env.example — copy to .env and fill in your values
# ──────────────────────────────────────────────────────────────────────────────

# ── Frontend (Vite) ────────────────────────────────────────────────────────────
# Base URL of your backend server (no trailing slash)
# Use Cloudflare Workers: https://needmo-workers.ibokchris.workers.dev
VITE_API_BASE_URL=https://needmo-workers.ibokchris.workers.dev


# ── Backend (server.js) ────────────────────────────────────────────────────────
# Cloudflare account ID — found at dash.cloudflare.com (right sidebar)
CLOUDFLARE_ACCOUNT_ID=your_account_id_here

# Cloudflare API token — needs Realtime Admin permissions
# Create at: dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_API_TOKEN=your_api_token_here

# RealtimeKit App ID — found at dash.realtime.cloudflare.com
CLOUDFLARE_REALTIMEKIT_APP_ID=your_app_id_here

# Preset name to apply to each participant
# Create presets at dash.realtime.cloudflare.com → Presets
# Default presets: "group_call_host", "group_call_participant", "webinar_viewer", "webinar_presenter"
REALTIMEKIT_PRESET_NAME=group_call_host

# Allowed CORS origin for the backend (your frontend dev URL)
CORS_ORIGIN=http://localhost:5173

# Port for the backend server
PORT=3001
